# ============================================================
# AZZURRA — EDGE FUNCTION ENVIRONMENT VARIABLES
# Copy this file and rename to .env (gitignored).
# Set these in: Supabase Dashboard → Settings → Edge Functions
# Or via CLI: supabase secrets set KEY=VALUE
# ============================================================

# Razorpay credentials
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

# These are automatically injected by Supabase into Edge Functions
# — you do NOT need to set them manually in the Supabase dashboard.
# They are listed here for local development reference only.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key

# ============================================================
# HOW TO SET SECRETS FOR DEPLOYED EDGE FUNCTIONS
#
# Via Supabase CLI:
#   supabase secrets set RAZORPAY_KEY_ID=rzp_live_xxx
#   supabase secrets set RAZORPAY_KEY_SECRET=your_secret
#
# Via Dashboard:
#   Supabase → Settings → Edge Functions → Secrets
# ============================================================
