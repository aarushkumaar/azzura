# Server Port
PORT=3000

# Database Connection URL (PostgreSQL)
# Format: postgresql://username:password@localhost:5432/azzura
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/azzura

# Razorpay Credentials
# Get these from Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE
RAZORPAY_KEY_SECRET=YOUR_SECRET_HERE

# Razorpay Webhook Secret
# Set this in Razorpay Dashboard -> Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
